# Copy to .env.local for local development. `.env.local` is gitignored.
# All settings have safe defaults in app/config.py — only override what differs.

# --- Environment ---
APP_ENV=dev
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
# Matches docker-compose Postgres. Use async URL for the app, sync for Alembic.
DATABASE_URL=postgresql+asyncpg://cms_app:cms_app@localhost:5433/cms
DATABASE_URL_SYNC=postgresql+psycopg2://cms_app:cms_app@localhost:5433/cms

# --- Redis ---
REDIS_URL=redis://:cms_redis@localhost:6379/0

# --- Auth ---
JWT_SECRET=changeme-local-dev-only-please-rotate-in-prod
JWT_TTL_SECONDS=3600

# --- Storage (GCS via fake-gcs-server in dev) ---
# Leave STORAGE_EMULATOR_HOST set to use the local emulator.
# Unset (comment out) to talk to real GCS.
STORAGE_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_VIDEO=sre-video-dev
GCS_BUCKET_BACKUPS=sre-backups-dev
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  # required when not using emulator

# --- One-time tokens (invitations + password resets) ---
# Defaults: 7-day invitation TTL, 1-hour reset TTL.
# INVITATION_TTL_SECONDS=604800
# PASSWORD_RESET_TTL_SECONDS=3600

# --- CEO bootstrap (read by scripts/seed_demo.py) ---
# CEO_EMAIL=sifatsikder2814@gmail.com
# CEO_NAME=Sifat Sikder
# Required, min 8 chars. The seeded CEO is forced through /change-password on
# first login, so this is short-lived — rotate immediately after first sign-in.
# CEO_INITIAL_PASSWORD=changeme-rotate-immediately

# --- Gmail send (used by Phase-3 backend notifications + frontend invitations) ---
# Run `uv run python scripts/setup_gmail_oauth.py` once to obtain the refresh token.
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_SENDER_ADDRESS=

# --- Google sign-in OAuth (NextAuth Google provider) ---
# Separate OAuth client from the Gmail-send one. Scope: openid email profile.
# Redirect URI: http://localhost:3001/api/auth/callback/google
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Drive OAuth (per-user; Phase 3 Task 3.3) ---
# Separate OAuth client from sign-in. Scope: drive.readonly.
# Redirect URI: http://localhost:8000/auth/google/drive/callback
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/auth/google/drive/callback
# After OAuth completes, the user is sent here so the frontend can flash a toast.
# GOOGLE_DRIVE_POST_AUTH_REDIRECT=http://localhost:3000/settings

# --- Token encryption (per-user OAuth refresh tokens; Phase 3) ---
# Fernet key. Generate once with:
#   uv run python scripts/gen_token_encryption_key.py
# TOKEN_ENCRYPTION_KEY=
