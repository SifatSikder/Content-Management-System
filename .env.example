# Copy to .env.local for local development. `.env.local` is gitignored.
# All settings have safe defaults in app/config.py — only override what differs.

# --- Environment ---
APP_ENV=dev
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
# Matches docker-compose Postgres. Use async URL for the app, sync for Alembic.
DATABASE_URL=postgresql+asyncpg://cms_app:cms_app@localhost:5433/cms
DATABASE_URL_SYNC=postgresql+psycopg2://cms_app:cms_app@localhost:5433/cms

# --- Redis ---
REDIS_URL=redis://:cms_redis@localhost:6379/0

# --- Auth ---
JWT_SECRET=changeme-local-dev-only-please-rotate-in-prod
JWT_TTL_SECONDS=3600
MAGIC_LINK_TTL_SECONDS=900

# --- Storage (GCS via fake-gcs-server in dev) ---
# Leave STORAGE_EMULATOR_HOST set to use the local emulator.
# Unset (comment out) to talk to real GCS.
STORAGE_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_VIDEO=sre-video-dev
GCS_BUCKET_BACKUPS=sre-backups-dev
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  # required when not using emulator

# --- Email (Resend) — wired in Phase 5; left empty for dev mocks ---
# RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@sonsrealestate.local

# --- WhatsApp (Cloud API) — wired in Phase 5; left empty for dev mocks ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GROUP_ID=
